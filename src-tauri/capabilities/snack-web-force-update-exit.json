{
  "identifier": "snack-web-force-update-exit",
  "description": "Allow the Snack web app to close the desktop shell after a forced update is cancelled.",
  "local": false,
  "remote": {
    "urls": [
      "https://snack.mechlabs.cn/*",
      "https://qasnack.mechlabs.cn/*",
      "http://localhost:3000/*",
      "http://127.0.0.1:3000/*"
    ]
  },
  "windows": [
    "main"
  ],
  "permissions": [
    "allow-exit-after-force-update-cancel"
  ]
}
